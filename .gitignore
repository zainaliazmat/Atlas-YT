# Secrets — never commit your real keys.
.env

# Python bytecode cache.
__pycache__/
*.pyc

# The agent's learned memory (runs + wins) is personal/local.
memory.json

# Talk-to-Scout conversation state (transcript + distilled summary) is personal.
chat_state.json
chat_state.json.corrupt-*

# Any local cache files the agent may write.
*_cache.json

# Local virtual environment.
venv/
.venv/

ReferanceVideos/
reference-analyst/standards/

# eval foundation generated data
atlas/eval/runs/
atlas/projects/_eval_loop_tmp/
**/eval_scorecard.json
scriptwriter/COACH_ADDENDUM.md
atlas/projects/_eval_holdout_tmp/

# coach soft-tier addenda (written to the owning specialist on accept) + coach test caches
**/COACH_ADDENDUM.md
*/.pytest_cache/

# Control Room runtime settings (dashboard-owned, not source)
atlas/dashboard/control_room_settings.json
