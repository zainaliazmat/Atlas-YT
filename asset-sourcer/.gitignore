# Secrets
.env

# Magpie's per-user chat memory (distilled summary + recovery backlog). Local only.
chat_state.json
chat_state.json.corrupt-*

# Engine run log
memory.json
memory.json.corrupt-*

# Generated manifests + downloaded assets (regenerable output). Drop these lines if
# you want them committed.
manifests/

# Atomic-write temp files (temp + rename); should never linger, but just in case.
*.tmp
*.tmp.*

# Python bytecode / caches
__pycache__/
*.pyc
