{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas/contracts/factcheck_report.schema.json",
  "title": "factcheck_report.json — the verdict the fact-check gate enforces",
  "type": "object",
  "required": ["schema_version", "verdict", "summary", "claims"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"type": "string"},
    "verdict": {"type": "string", "enum": ["pass", "block"]},
    "summary": {
      "type": "object",
      "required": ["verified", "flagged", "unverifiable"],
      "additionalProperties": true,
      "properties": {
        "verified": {"type": "integer"},
        "flagged": {"type": "integer"},
        "unverifiable": {"type": "integer"}
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "status"],
        "additionalProperties": true,
        "properties": {
          "claim_id": {"type": "string"},
          "scene_no": {"type": "integer"},
          "claim_text": {"type": "string"},
          "status": {"type": "string",
                     "enum": ["verified", "flagged", "unverifiable"]},
          "sources": {"type": "array"},
          "note": {"type": "string"}
        }
      }
    }
  }
}
