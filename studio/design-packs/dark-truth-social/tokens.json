{
  "colors": {
    "paper": "#f2eed6",
    "paper-shade": "#e4e0c8",
    "ink": "#1f1f1e",
    "charcoal": "#3a3a39",
    "spray": "#2e5e1f",
    "spray-deep": "#1a5614",
    "lime": "#8fb573",
    "paper-line": "#c9c5ae"
  },
  "type": {
    "hero": { "font": "Rubik Spray Paint", "weight": 400 },
    "slab": { "font": "Roboto Slab", "weight": 900 },
    "mono": { "font": "Space Mono", "weight": 400 },
    "body": { "font": "Inter", "weight": 400 },
    "signature": { "font": "Sacramento", "weight": 400 }
  },
  "motion": {
    "fps": 30,
    "eases": [
      "power1.inOut",
      "power2.out",
      "power2.inOut",
      "power3.in",
      "power3.out",
      "sine.out",
      "sine.inOut",
      "expo.out",
      "back.out(1.6)",
      "steps(1)",
      "none"
    ],
    "budget": {
      "max_shader_transitions": 2,
      "transition_overlap_sec": [0.18, 0.4],
      "alive_always_on": true
    }
  },
  "textures": ["halftone", "spray-rough", "grain"]
}
