# Copy this file to ".env" and paste your real keys after the "=".
# Never commit the real .env — it is git-ignored for you.
#
# Cadence's DEFAULT brain (Claude on your Claude Code subscription) needs NO key, and
# the engine's only LLM use (mood -> music query) degrades to a deterministic fallback
# when offline. So the out-of-the-box setup needs NOTHING in this file.

# --- LLM brain (chat REPL + memory distiller + the mood->query curation) -----
# DEFAULT (AUDIO_LLM unset) = Claude on your Claude Code SUBSCRIPTION via the Agent
# SDK. No key required. Do NOT set ANTHROPIC_API_KEY — it is NOT needed for the
# default, and if set it makes the SDK bill the pay-per-token API instead of your
# subscription (llm.py warns you if it sees it).
#
# Switch brains with the AUDIO_LLM env var (one switch, see llm.py):
#   AUDIO_LLM=gemini    -> needs GEMINI_API_KEY below
#   AUDIO_LLM=deepseek  -> needs DEEPSEEK_API_KEY below

# Google Gemini (free) — only for AUDIO_LLM=gemini (and the weak-model persona test).
# GEMINI_API_KEY=your-free-gemini-api-key-here

# DeepSeek — only for AUDIO_LLM=deepseek.
# DEEPSEEK_API_KEY=your-deepseek-api-key-here

# --- Narration voice (optional) ----------------------------------------------
# Kokoro voice for tts. Default af_heart. Options include af_heart, af_nova, af_sky,
# am_adam, am_michael, bf_emma, bf_isabella, bm_george (see `npx hyperframes tts --list`).
# CADENCE_VOICE=af_heart

# --- Audio source-API keys (ALL optional + free; a missing key skips that source) --
# Most of Cadence's allowlist is keyless (Openverse audio, Wikimedia Commons audio,
# Internet Archive audio). Freesound is the only keyed source — Cadence silently skips
# it when the key is absent, and the bundled CC0 SFX kit means the signature accent
# never depends on it anyway.
# FREESOUND_API_KEY=your-free-freesound-key
