# Secrets
.env

# Marlow's per-user chat memory (distilled summary + recovery backlog). Local only.
chat_state.json
chat_state.json.corrupt-*

# Engine run log
memory.json
memory.json.corrupt-*

# Generated scripts (regenerable output). Drop this line if you want them committed.
scripts/

# Atomic-write temp files (temp + rename); should never linger, but just in case.
*.tmp.*

# Python bytecode / caches
__pycache__/
*.pyc
